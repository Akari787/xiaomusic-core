{
  "name": "SoundScape 1:1",
  "layout": "soundscape",
  "css": ":root {\n  --ss-accent: #31c27c;\n  --ss-accent-strong: #27a867;\n  --ss-bg: #f3f6f5;\n  --ss-panel: #ffffff;\n  --ss-border: #e3e8e6;\n  --ss-text: #27343a;\n  --ss-muted: #7f8b92;\n}\n\nbody.index_page.webui-refactor-mode {\n  background: linear-gradient(140deg, #dfeee6 0%, #edf2f0 36%, #f8fafa 100%) !important;\n  padding: 12px !important;\n  display: block !important;\n  min-height: 100vh !important;\n}\n\n.soundscape-app {\n  width: calc(100vw - 24px);\n  height: calc(100vh - 24px);\n  display: grid;\n  grid-template-columns: 238px minmax(0, 1fr);\n  grid-template-rows: minmax(0, 1fr) 72px;\n  grid-template-areas: \"sidebar main\" \"sidebar dock\";\n  background: var(--ss-panel);\n  border-radius: 18px;\n  border: 1px solid var(--ss-border);\n  overflow: hidden;\n  box-shadow: 0 22px 60px rgba(27, 56, 47, 0.14);\n}\n\n.soundscape-sidebar {\n  grid-area: sidebar;\n  background: #f7f9f8;\n  border-right: 1px solid var(--ss-border);\n  display: flex;\n  flex-direction: column;\n  min-height: 0;\n}\n\n.soundscape-brand {\n  padding: 22px 20px 14px;\n}\n\n.soundscape-brand h1 {\n  margin: 0;\n  font-size: 36px;\n  line-height: 1;\n  color: #202a31;\n  font-weight: 750;\n  letter-spacing: -0.01em;\n}\n\n.soundscape-brand p {\n  margin: 6px 0 0;\n  font-size: 12px;\n  color: var(--ss-muted);\n}\n\n.soundscape-sidebar-head {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 8px 18px 8px;\n  font-size: 13px;\n  color: #43525a;\n  font-weight: 600;\n}\n\n.soundscape-refresh {\n  width: 28px;\n  height: 28px;\n  border: none;\n  border-radius: 8px;\n  background: transparent;\n  cursor: pointer;\n}\n\n.soundscape-refresh .material-icons {\n  font-size: 18px;\n  color: #809099 !important;\n}\n\n.soundscape-refresh:hover {\n  background: #eef2f0;\n}\n\n.soundscape-playlist-list {\n  padding: 0 12px 10px;\n  overflow: auto;\n  min-height: 0;\n}\n\n.soundscape-playlist-item {\n  width: 100%;\n  border: none;\n  background: transparent;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  height: 34px;\n  border-radius: 8px;\n  padding: 0 12px;\n  color: #4f6068;\n  cursor: pointer;\n  text-align: left;\n  font-size: 13px;\n}\n\n.soundscape-playlist-item:hover {\n  background: #eef2f0;\n}\n\n.soundscape-playlist-item.active {\n  background: linear-gradient(135deg, #3bc788 0%, #2cb372 100%);\n  color: #fff;\n}\n\n.soundscape-playlist-count {\n  font-size: 12px;\n  opacity: 0.85;\n}\n\n.soundscape-settings-entry {\n  margin: auto 12px 12px;\n  border: none;\n  background: #eef3f1;\n  color: #4b5f67;\n  height: 38px;\n  border-radius: 10px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  cursor: pointer;\n}\n\n.soundscape-main {\n  grid-area: main;\n  min-height: 0;\n  display: flex;\n  flex-direction: column;\n  background: #fbfcfc;\n}\n\n.soundscape-toolbar {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 86px auto;\n  gap: 10px;\n  padding: 16px 16px 10px;\n  border-bottom: 1px solid var(--ss-border);\n}\n\n.soundscape-toolbar input {\n  min-height: 38px;\n  border-radius: 19px;\n  border: 1px solid #dfe6e3;\n  padding: 0 14px;\n  background: #fff;\n}\n\n.soundscape-toolbar button {\n  min-height: 38px;\n  border: none;\n  border-radius: 19px;\n  background: linear-gradient(135deg, var(--ss-accent) 0%, var(--ss-accent-strong) 100%);\n  color: #fff;\n  cursor: pointer;\n}\n\n.soundscape-toolbar-right {\n  display: flex;\n  align-items: center;\n  justify-content: flex-end;\n  font-size: 12px;\n  color: #8d99a0;\n  white-space: nowrap;\n  padding-right: 6px;\n}\n\n.soundscape-meta-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  padding: 10px 16px;\n}\n\n.soundscape-meta-chip {\n  background: rgba(49, 194, 124, 0.16);\n  color: #1f7f57;\n  border-radius: 999px;\n  padding: 5px 11px;\n  font-size: 12px;\n  font-weight: 600;\n}\n\n.soundscape-device-group {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.soundscape-device-group .device-selector {\n  width: 260px !important;\n  margin: 0 !important;\n  min-height: 34px !important;\n  border: 1px solid #dce4e1 !important;\n  border-radius: 8px !important;\n  padding: 0 10px !important;\n  background: #fff !important;\n  color: #34464f !important;\n}\n\n.soundscape-device-group .toggle-switch {\n  margin: 0;\n}\n\n.soundscape-table-wrap {\n  margin: 0 16px 14px;\n  border: 1px solid var(--ss-border);\n  border-radius: 10px;\n  background: #fff;\n  overflow: auto;\n  min-height: 0;\n  flex: 1;\n}\n\n.soundscape-table {\n  width: 100%;\n  border-collapse: collapse;\n  table-layout: fixed;\n}\n\n.soundscape-table th {\n  text-align: left;\n  font-size: 12px;\n  color: #7f8e95;\n  font-weight: 600;\n  padding: 10px 14px;\n  background: #fafcfc;\n  border-bottom: 1px solid var(--ss-border);\n}\n\n.soundscape-table th:nth-child(1),\n.soundscape-table td:nth-child(1) {\n  width: 46px;\n}\n\n.soundscape-table th:nth-child(3),\n.soundscape-table td:nth-child(3) {\n  width: 84px;\n  text-align: center;\n}\n\n.soundscape-table td {\n  border-bottom: 1px solid #edf1ef;\n  color: #30404a;\n  padding: 11px 14px;\n  font-size: 13px;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.soundscape-table tr.active {\n  background: rgba(49, 194, 124, 0.08);\n}\n\n.soundscape-table tr:hover {\n  background: #f5f8f7;\n}\n\n.soundscape-table td button {\n  border: none;\n  border-radius: 6px;\n  background: rgba(49, 194, 124, 0.16);\n  color: #1f7f57;\n  padding: 4px 10px;\n  cursor: pointer;\n  font-size: 12px;\n}\n\n.soundscape-table td button:hover {\n  background: rgba(49, 194, 124, 0.26);\n}\n\n.soundscape-dock {\n  grid-area: dock;\n  background: #fff;\n  border-top: 1px solid var(--ss-border);\n  display: grid;\n  grid-template-columns: minmax(220px, 1fr) auto minmax(180px, 1fr);\n  align-items: center;\n  padding: 0 14px;\n  gap: 12px;\n}\n\n.soundscape-dock-left {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  min-width: 0;\n}\n\n.soundscape-dock-main-btn {\n  width: 42px;\n  height: 42px;\n  border: none;\n  border-radius: 12px;\n  background: linear-gradient(135deg, #3bc788 0%, #2cb372 100%);\n  color: #fff;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.soundscape-dock-main-btn .material-icons-outlined {\n  font-size: 30px;\n  color: #fff !important;\n}\n\n.soundscape-dock-song {\n  font-size: 13px;\n  color: #34464f;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.soundscape-dock-center {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n}\n\n.soundscape-dock-center button {\n  width: 34px;\n  height: 34px;\n  border: none;\n  border-radius: 8px;\n  background: #f0f4f2;\n  color: #4f6068;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.soundscape-dock-center button:hover {\n  background: #e6eeea;\n}\n\n.soundscape-dock-right {\n  font-size: 12px;\n  color: #8a979e;\n  text-align: right;\n}\n\n.component-overlay {\n  background: rgba(26, 35, 31, 0.45) !important;\n}\n\n.component,\n.component#settings-component {\n  background: rgba(255, 255, 255, 0.97) !important;\n  border: 1px solid #dce6e1 !important;\n  border-radius: 16px !important;\n}\n\n@media (max-width: 1100px) {\n  .soundscape-app {\n    grid-template-columns: 1fr;\n    grid-template-rows: minmax(0, auto) minmax(0, 1fr) 72px;\n    grid-template-areas: \"sidebar\" \"main\" \"dock\";\n    height: auto;\n    min-height: calc(100vh - 24px);\n  }\n\n  .soundscape-sidebar {\n    border-right: none;\n    border-bottom: 1px solid var(--ss-border);\n    max-height: 230px;\n  }\n}\n\n@media (max-width: 720px) {\n  .soundscape-toolbar {\n    grid-template-columns: minmax(0, 1fr) 84px;\n  }\n\n  .soundscape-toolbar-right {\n    grid-column: span 2;\n    justify-content: flex-start;\n  }\n\n  .soundscape-meta-row {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .soundscape-device-group {\n    width: 100%;\n  }\n\n  .soundscape-device-group .device-selector {\n    width: 100% !important;\n  }\n\n  .soundscape-dock {\n    grid-template-columns: 1fr;\n    height: auto;\n    padding: 8px 12px 12px;\n    gap: 8px;\n  }\n\n  .soundscape-dock-right {\n    text-align: left;\n  }\n}\n"
}
