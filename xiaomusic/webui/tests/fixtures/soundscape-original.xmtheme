{
  "name": "SoundScape Classic",
  "css": ":root {\n  --ss-accent: #31c27c;\n  --ss-accent-strong: #27a867;\n  --ss-accent-soft: rgba(49, 194, 124, 0.16);\n  --ss-bg-a: #eef6f2;\n  --ss-bg-b: #f8fafb;\n  --ss-panel: rgba(255, 255, 255, 0.86);\n  --ss-border: rgba(159, 181, 169, 0.42);\n  --ss-text: #1f2c27;\n  --ss-muted: #5e7168;\n}\n\nbody.index_page.webui-refactor-mode {\n  background: radial-gradient(circle at 0% 0%, #dff4e8 0%, #ecf5ef 38%, #f7f8fb 100%) !important;\n  color: var(--ss-text) !important;\n}\n\n.player,\n.component#settings-component,\n.setting-card,\n.button-section,\n.link-card,\n.oauth-status-item,\n.status-pill,\n.component {\n  background: var(--ss-panel) !important;\n  border: 1px solid var(--ss-border) !important;\n  box-shadow: 0 14px 34px rgba(50, 84, 72, 0.16) !important;\n  backdrop-filter: blur(8px);\n}\n\nh1,\n.component h2,\n.component h3,\n.card-title,\n.button-section-title,\n.link-card-title,\nlabel {\n  color: var(--ss-text) !important;\n}\n\np,\nspan,\n.link-card-description,\n.oauth-label,\n.oauth-hint,\n.version-number {\n  color: var(--ss-muted) !important;\n}\n\na,\n.material-icons {\n  color: var(--ss-accent) !important;\n}\n\ninput,\ntextarea,\nselect {\n  background: rgba(255, 255, 255, 0.95) !important;\n  color: #24362f !important;\n  border: 1px solid #b9d5c8 !important;\n  border-radius: 12px !important;\n}\n\ninput:focus,\ntextarea:focus,\nselect:focus {\n  border-color: var(--ss-accent) !important;\n  box-shadow: 0 0 0 3px rgba(49, 194, 124, 0.18) !important;\n}\n\nbutton,\n.component-button-group button,\n.button-grid button,\n.theme-select-row button {\n  background: linear-gradient(135deg, var(--ss-accent) 0%, var(--ss-accent-strong) 100%) !important;\n  border: 1px solid rgba(34, 120, 81, 0.2) !important;\n  color: #fff !important;\n  border-radius: 12px !important;\n}\n\nbutton:hover,\n.component-button-group button:hover,\n.button-grid button:hover,\n.theme-select-row button:hover {\n  filter: brightness(1.03);\n  box-shadow: 0 10px 20px rgba(39, 168, 103, 0.26) !important;\n}\n\n.config-tabs,\n.auth-tabs {\n  background: rgba(236, 245, 239, 0.9) !important;\n  border: 1px solid rgba(173, 201, 188, 0.52) !important;\n}\n\n.config-tab-button,\n.auth-tab-button {\n  color: #5a6e64 !important;\n}\n\n.config-tab-button.active,\n.auth-tab-button.active {\n  color: #1f2c27 !important;\n  background: rgba(255, 255, 255, 0.95) !important;\n  box-shadow: 0 6px 14px rgba(59, 95, 81, 0.16) !important;\n}\n\n.advanced-config-toggle {\n  background: linear-gradient(135deg, #dff3e7 0%, #e9f7ef 100%) !important;\n  border: 1px solid #9fd3b8 !important;\n}\n\n.advanced-config-toggle-text,\n.advanced-config-toggle-icon {\n  color: #1f6848 !important;\n}\n\n.section-header {\n  border-bottom: 1px solid #cfe2d8 !important;\n}\n\n.section-header:hover {\n  border-bottom-color: var(--ss-accent) !important;\n}\n\n.section-toggle-icon {\n  color: var(--ss-accent) !important;\n}\n\n.control-button,\n.icon-item {\n  background: rgba(255, 255, 255, 0.92) !important;\n  border: 1px solid #bfdacc !important;\n  border-radius: 14px !important;\n}\n\n.control-button .material-icons,\n.control-button .material-icons-outlined,\n.icon-item .material-icons,\n.icon-item p {\n  color: #3f5950 !important;\n}\n\n.control-button:hover,\n.icon-item:hover {\n  background: var(--ss-accent-soft) !important;\n  border-color: rgba(49, 194, 124, 0.55) !important;\n}\n\n.control-button:hover .material-icons,\n.control-button:hover .material-icons-outlined,\n.icon-item:hover .material-icons,\n.icon-item:hover p {\n  color: #1f6848 !important;\n}\n\n.control-button:has(.play) {\n  background: linear-gradient(135deg, var(--ss-accent) 0%, var(--ss-accent-strong) 100%) !important;\n  border-color: rgba(34, 120, 81, 0.25) !important;\n}\n\n.control-button:has(.play) .material-icons-outlined {\n  color: #ffffff !important;\n}\n\n.mode-controls {\n  border-top: 1px solid #c9dfd3 !important;\n}\n\n.link-card-icon {\n  background: rgba(49, 194, 124, 0.14) !important;\n}\n\n.link-card:hover {\n  border-color: rgba(49, 194, 124, 0.58) !important;\n  box-shadow: 0 10px 22px rgba(49, 194, 124, 0.2) !important;\n}\n"
}
