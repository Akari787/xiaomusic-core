# Required
HTTP_AUTH_HASH=$2b$12$replace_with_bcrypt_hash

# Optional runtime
TZ=Asia/Shanghai
XIAOMUSIC_PUBLIC_PORT=58090
XIAOMUSIC_LOG_FILE=/app/conf/xiaomusic.log.txt
XIAOMUSIC_AUTH_TOKEN_FILE=auth.json
AUTH_REFRESH_INTERVAL_HOURS=12
AUTH_REFRESH_MIN_INTERVAL_MINUTES=30

# Optional auth overrides
# AUTH_ACCESS_TOKEN=
# AUTH_REFRESH_TOKEN=

# Security defaults
XIAOMUSIC_ENABLE_EXEC_PLUGIN=false
XIAOMUSIC_ENABLE_ANALYTICS=false
XIAOMUSIC_ENABLE_SELF_UPDATE=false
XIAOMUSIC_LOG_REDACT=true
XIAOMUSIC_PERSIST_TOKEN=true

# CORS / outbound
XIAOMUSIC_CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1
XIAOMUSIC_OUTBOUND_ALLOWLIST_DOMAINS=

# Worker model (must remain single worker)
UVICORN_WORKERS=1
WEB_CONCURRENCY=1

# Only required when analytics enabled
# API_SECRET=replace_with_secret
